# Copy to `.env` and fill in. Never commit `.env`.

# Your OpenAI key (from platform.openai.com) — Rocket Ride variable name
ROCKETRIDE_OPENAI_KEY=

# Same key also works for the local Next.js pipeline
OPENAI_API_KEY=

# Optional: when Rocket Ride Cloud is deployed, set the pipeline invoke URL
# ROCKETRIDE_PIPELINE_URL=
